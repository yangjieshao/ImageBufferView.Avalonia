<Window
    x:Class="ImageBufferView.Avalonia.Sample.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ibv="clr-namespace:ImageBufferView.Avalonia;assembly=ImageBufferView.Avalonia"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:ImageBufferView.Avalonia.Sample.ViewModels"
    Title="ImageBufferView.Avalonia.Sample"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="vm:MainWindowViewModel"
    Icon="/Assets/avalonia-logo.ico"
    mc:Ignorable="d">

    <Window.DataContext>
        <!--
            This only sets the DataContext for the previewer in an IDE,
            to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs)
        -->
        <vm:MainWindowViewModel />
    </Window.DataContext>

    <Grid ColumnDefinitions="*,310">
        <Grid
            Background="GreenYellow"
            ColumnDefinitions="auto,*,*,*"
            RowDefinitions="50,*,*,*,*">

            <Grid
                Grid.Row="0"
                Grid.Column="0"
                ColumnDefinitions="auto,auto,auto,auto,auto">

                <Button
                    Grid.Column="0"
                    Height="30"
                    Padding="5,5"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Command="{Binding Start}"
                    Content="Start"
                    Cursor="Hand"
                    IsVisible="{Binding CancellationTokenSource, Converter={x:Static ObjectConverters.IsNull}}" />

                <Button
                    Grid.Column="0"
                    Height="30"
                    Padding="5,5"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Command="{Binding Pause}"
                    Content="Pause"
                    Cursor="Hand"
                    IsVisible="{Binding CancellationTokenSource, Converter={x:Static ObjectConverters.IsNotNull}}" />

                <Button
                    Grid.Column="1"
                    Height="30"
                    Padding="5,5"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Command="{Binding Clean}"
                    Content=" Clean"
                    Cursor="Hand" />

                <Button
                    Grid.Column="2"
                    Height="30"
                    Padding="5,5"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Command="{Binding SwitchFormat}"
                    Content="Switch"
                    Cursor="Hand"
                    IsVisible="{Binding CancellationTokenSource, Converter={x:Static ObjectConverters.IsNotNull}}" />

                <TextBlock
                    Grid.Column="3"
                    Margin="5,0"
                    VerticalAlignment="Center"
                    Text="{Binding CurrentFormatName}" />


            </Grid>

            <TextBlock
                Grid.Row="0"
                Grid.Column="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Text="Both" />
            <TextBlock
                Grid.Row="0"
                Grid.Column="2"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Text="UpOnly" />
            <TextBlock
                Grid.Row="0"
                Grid.Column="3"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Text="DownOnly" />

            <TextBlock
                Grid.Row="1"
                Grid.Column="0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Text="None" />
            <TextBlock
                Grid.Row="2"
                Grid.Column="0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Text="Fill" />
            <TextBlock
                Grid.Row="3"
                Grid.Column="0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Text="Uniform" />
            <TextBlock
                Grid.Row="4"
                Grid.Column="0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Text="UniformToFill" />

            <ibv:ImageBufferView
                Name="FirstPic"
                Grid.Row="1"
                Grid.Column="1"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                DefaultBackground="Black"
                ImageBuffer="{Binding ImageBuffer}"
                InterpolationMode="LowQuality"
                PixelBufferFormat="{Binding PixelBufferFormat}"
                RawImageHeight="128"
                RawImageWidth="128"
                Stretch="None"
                StretchDirection="Both" />

            <ibv:ImageBufferView
                Grid.Row="1"
                Grid.Column="2"
                DefaultBackground="AliceBlue"
                InterpolationMode="LowQuality"
                SourceView="{Binding ElementName=FirstPic}"
                Stretch="None"
                StretchDirection="UpOnly" />

            <ibv:ImageBufferView
                Grid.Row="1"
                Grid.Column="3"
                DefaultBackground="BurlyWood"
                InterpolationMode="LowQuality"
                SourceView="{Binding ElementName=FirstPic}"
                Stretch="None"
                StretchDirection="DownOnly" />

            <ibv:ImageBufferView
                Grid.Row="2"
                Grid.Column="1"
                DefaultBackground="Chocolate"
                InterpolationMode="LowQuality"
                SourceView="{Binding ElementName=FirstPic}"
                Stretch="Fill"
                StretchDirection="Both" />

            <ibv:ImageBufferView
                Grid.Row="2"
                Grid.Column="2"
                InterpolationMode="LowQuality"
                SourceView="{Binding ElementName=FirstPic}"
                Stretch="Fill"
                StretchDirection="UpOnly">
                <ibv:ImageBufferView.DefaultBackground>
                    <ImageBrush Source="/Assets/Camera.png" Stretch="UniformToFill" />
                </ibv:ImageBufferView.DefaultBackground>
            </ibv:ImageBufferView>

            <ibv:ImageBufferView
                Grid.Row="2"
                Grid.Column="3"
                InterpolationMode="LowQuality"
                SourceView="{Binding ElementName=FirstPic}"
                Stretch="Fill"
                StretchDirection="DownOnly">
                <ibv:ImageBufferView.DefaultBackground>
                    <ImageBrush Source="/Assets/card.png" Stretch="Fill" />
                </ibv:ImageBufferView.DefaultBackground>
            </ibv:ImageBufferView>

            <ibv:ImageBufferView
                Grid.Row="3"
                Grid.Column="1"
                DefaultBackground="DarkGray"
                InterpolationMode="LowQuality"
                SourceView="{Binding ElementName=FirstPic}"
                Stretch="Uniform"
                StretchDirection="Both" />

            <ibv:ImageBufferView
                Grid.Row="3"
                Grid.Column="2"
                DefaultBackground="Gainsboro"
                InterpolationMode="LowQuality"
                SourceView="{Binding ElementName=FirstPic}"
                Stretch="Uniform"
                StretchDirection="UpOnly" />

            <ibv:ImageBufferView
                Grid.Row="3"
                Grid.Column="3"
                DefaultBackground="DarkGreen"
                InterpolationMode="LowQuality"
                SourceView="{Binding ElementName=FirstPic}"
                Stretch="Uniform"
                StretchDirection="DownOnly" />

            <ibv:ImageBufferView
                Grid.Row="4"
                Grid.Column="1"
                DefaultBackground="FloralWhite"
                InterpolationMode="LowQuality"
                SourceView="{Binding ElementName=FirstPic}"
                Stretch="UniformToFill"
                StretchDirection="Both" />

            <ibv:ImageBufferView
                Grid.Row="4"
                Grid.Column="2"
                DefaultBackground="Linen"
                InterpolationMode="LowQuality"
                SourceView="{Binding ElementName=FirstPic}"
                Stretch="UniformToFill"
                StretchDirection="UpOnly" />

            <ibv:ImageBufferView
                Grid.Row="4"
                Grid.Column="3"
                InterpolationMode="LowQuality"
                SourceView="{Binding ElementName=FirstPic}"
                Stretch="UniformToFill"
                StretchDirection="DownOnly" />
        </Grid>
        <!--#region 实时画面-->

        <Grid
            Grid.Column="1"
            Background="BlueViolet"
            RowDefinitions="auto,30,30,30,30,*">
            <ibv:ImageBufferView
                Name="CameraView"
                Grid.Row="0"
                Width="300"
                Height="300"
                Margin="5"
                FrameIndex="{Binding UsbCamera.FrameIndex}"
                ImageBuffer="{Binding UsbCamera.CurrentImageBuffer}"
                InterpolationMode="HighQuality"
                PixelBufferFormat="{Binding UsbCamera.CurrentPixelBufferFormat}"
                RawImageHeight="{Binding UsbCamera.CurrentImageHeight}"
                RawImageWidth="{Binding UsbCamera.CurrentImageWidth}"
                Stretch="Uniform"
                StretchDirection="Both">
                <ibv:ImageBufferView.DefaultBackground>
                    <ImageBrush Source="/Assets/Camera.png" Stretch="UniformToFill" />
                </ibv:ImageBufferView.DefaultBackground>
            </ibv:ImageBufferView>
            <ComboBox
                Grid.Row="1"
                Margin="5"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                ItemsSource="{Binding UsbCamera.DeviceList}"
                SelectedItem="{Binding UsbCamera.Device, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <TextBlock IsVisible="{Binding Converter={x:Static ObjectConverters.IsNotNull}}" Text="{Binding Name}" />
                            <TextBlock IsVisible="{Binding Converter={x:Static ObjectConverters.IsNull}}" Text="无设备" />
                        </Grid>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <ComboBox
                Grid.Row="2"
                Margin="5"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                ItemsSource="{Binding UsbCamera.CharacteristicList}"
                SelectedItem="{Binding UsbCamera.Characteristic, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <StackPanel
                Grid.Row="3"
                HorizontalAlignment="Center"
                Orientation="Horizontal"
                Spacing="6">
                <Button x:Name="RotateLeftButton" Content="Rotate -90°" />
                <Button x:Name="RotateRightButton" Content="Rotate +90°" />
                <Button x:Name="Rotate180Button" Content="Rotate 180°" />
            </StackPanel>

            <StackPanel
                Grid.Row="4"
                HorizontalAlignment="Center"
                Orientation="Horizontal"
                Spacing="6">
                <Button x:Name="FlipHorizontalButton" Content="Flip H" />
                <Button x:Name="FlipVerticalButton" Content="Flip V" />
                <Button x:Name="ResetTransformButton" Content="Reset" />
            </StackPanel>

            <ibv:ImageBufferView
                Grid.Row="5"
                Margin="5"
                ImageBuffer="{Binding ImageBuffer2}"
                InterpolationMode="LowQuality"
                Stretch="UniformToFill"
                StretchDirection="DownOnly" />
        </Grid>

        <!--#endregion 实时画面-->
    </Grid>
</Window>
